{
    "name": "mcui-oreui",
    "version": "1.1.0",
    "description": "Minecraft 基岩版 Ore UI 设计语言的 Vue 3 组件库（第三方复刻，移植自 Spectrollay-OreUI）",
    "keywords": [
        "minecraft",
        "ore-ui",
        "oreui",
        "bedrock",
        "vue",
        "vue3",
        "vue-component",
        "component-library",
        "ui",
        "ui-kit",
        "pixel",
        "minecraft-ui"
    ],
    "license": "MIT",
    "author": "ShenYuanOL (https://github.com/ShenYuanOL)",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ShenYuanOR/mcui-oreui.git"
    },
    "homepage": "https://shenyuanor.github.io/mcui-oreui/",
    "bugs": {
        "url": "https://github.com/ShenYuanOR/mcui-oreui/issues"
    },
    "type": "module",
    "sideEffects": [
        "**/*.css"
    ],
    "files": [
        "dist"
    ],
    "main": "./dist/mcui-oreui.umd.cjs",
    "module": "./dist/mcui-oreui.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/mcui-oreui.js",
            "require": "./dist/mcui-oreui.umd.cjs"
        },
        "./style.css": "./dist/mcui-oreui.css"
    },
    "scripts": {
        "build": "vue-tsc -p tsconfig.build.json && vite build",
        "docs:dev": "vitepress dev docs",
        "docs:build": "vitepress build docs",
        "docs:preview": "vitepress preview docs",
        "prepublishOnly": "npm run build"
    },
    "peerDependencies": {
        "vue": "^3.3.0"
    },
    "devDependencies": {
        "@types/node": "^20.14.9",
        "@vitejs/plugin-vue": "^5.0.5",
        "typescript": "^5.4.5",
        "vite": "^5.3.1",
        "vite-plugin-dts": "^3.9.1",
        "vitepress": "^1.2.3",
        "vue": "^3.4.31",
        "vue-tsc": "^2.0.24"
    }
}
